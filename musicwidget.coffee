#if this lags too much use the exact full pathname i.e. command: "osascript '/Users/{YOUR DIRECTORY}}/Library/Application Support/Übersicht/widgets/Music/musicwidget.scpt'"
command: "osascript \"#{__dirname}/musicwidget.scpt\""

refreshFrequency: 250 #edit this if lagging

render: -> 
    # base-64 image of the ipod frame (static)
    img = "data:image/png;base64,"
    
    """
    <div class = "music-player">
        <img src = "#{img}" class = "ipod-image">

        <div class = "screen">
            <div class = "track"> </div>
            <div class = "artist"> </div>
            <div class = "album-cover"> </div>

            <div class = "progress-bar">
                <div class="progress-fill"></div>
            </div>

            <div class="time-row">
                <span class="current-time">0:00</span>
                <span class="total-time">0:00</span>
            </div>

            <div class="button music-button"> </div>
            <div class="button back-button"></div>
            <div class="button forward-button"></div>
            <div class="button playpause-button"></div>
        </div>
    </div>
    """

#runs once after widget is inserted into DOM
afterRender: (domEl) ->
    widget = $(domEl) #root 
    widget.off() #removes previous event handlers

    widget.on 'click', '.back-button', =>
        @run "osascript -e 'tell application \"Spotify\" to previous track'"

    widget.on 'click', '.forward-button', =>
        @run "osascript -e 'tell application \"Spotify\" to next track'"

    widget.on 'click', '.playpause-button', =>
        @run "osascript -e 'tell application \"Spotify\" to playpause'"

    widget.on 'click', '.music-button', =>
        @run "open -a Spotify"

#runs every refresh cycle & updates ui with applescript data
update: (output, domEl) ->
  try
    #log the raw output (FOR DEBUGGING !!)
    console.log("raw output:", output)

    #parse json string into a usable object
    data = JSON.parse(output)

    #grab elements from spotify
    trackEl = domEl.querySelector('.track')
    artistEl = domEl.querySelector('.artist')
    progressFill = domEl.querySelector('.progress-fill')

    #update text (fallback if nothing is playing)
    trackEl.innerText = data.track or "no music playing ✰˚.⋆"
    artistEl.innerText = data.artist or "*ੈ✩‧₊˚"

    coverEl = domEl.querySelector('.album-cover')

    #only update art when the track changes!! avoids reloading
    if data.track isnt @lastTrack
        @lastTrack = data.track
        if data.image? and data.image isnt ""
            #use the base-64 image
            coverEl.style.backgroundImage = "url(data:image/jpeg;base64,#{data.image})"
            coverEl.style.backgroundSize = "cover"
            coverEl.style.backgroundPosition = "center"
        else
            coverEl.style.backgroundImage = "none"

    #time stuff
    currentTimeEl = domEl.querySelector('.current-time')
    totalTimeEl = domEl.querySelector('.total-time')

    #converts seconds to mm:ss
    formatTime = (secs) ->
        secs = Math.floor(secs or 0)
        mins = Math.floor(secs / 60)
        secs = secs % 60
        secs = "0#{secs}" if secs < 10
        "#{mins}:#{secs}"

    currentTimeEl.innerText = formatTime(data.position)
    totalTimeEl.innerText = formatTime(data.duration)

    #adjusts text alignment if its overflowing
    trackEl.classList.remove('bottom-align', 'top-align')

    if trackEl.scrollHeight > trackEl.clientHeight
      trackEl.classList.add('top-align')
    else
      trackEl.classList.add('bottom-align')

    #update progress bar based on percent into song
    if data.duration? and data.duration > 0
      percent = Math.min(100, (data.position / data.duration) * 100)
      progressFill.style.width = "#{percent}%"
    else
      progressFill.style.width = "0%"

    #dim the song if paused
    if data.state is "paused"
      domEl.querySelector('.track').style.opacity = "0.6"
      domEl.querySelector('.artist').style.opacity = "0.6"
    else
      domEl.querySelector('.track').style.opacity = "1"
      domEl.querySelector('.artist').style.opacity = "0.85"

  catch err
    #fallbacks in case something fails
    console.log("parse error:", err)
    domEl.querySelector('.track').innerText = "Widget error"
    domEl.querySelector('.artist').innerText = output

